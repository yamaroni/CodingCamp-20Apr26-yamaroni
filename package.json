{
  "name": "todo-list-life-dashboard",
  "version": "1.0.0",
  "description": "A personal productivity dashboard with tasks, timer, and quick links",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["dashboard", "productivity", "todo"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["js/**/*.js"],
    "coveragePathIgnorePatterns": ["/node_modules/"]
  }
}
